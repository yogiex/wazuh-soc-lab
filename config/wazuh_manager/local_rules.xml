<group name="sangfor,ngaf,waf,firewall,">

  <!-- ============================================ -->
  <!-- Sangfor NGAF Rules                           -->
  <!-- ============================================ -->

  <rule id="100002" level="10">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="actions">blocked</field>
    <description>Sangfor NGAF: Blocked traffic from $(srcip) to $(dstip) — $(policy)</description>
    <group>attack,blocked,</group>
    <mitre>
      <id>T1562.004</id>
      <tactic>Defense Evasion</tactic>
      <technique>Impair Defenses</technique>
    </mitre>
  </rule>

  <rule id="100003" level="12">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="severity">high</field>
    <description>Sangfor NGAF: High severity alert — $(type) from $(srcip) to $(dstip)</description>
    <group>attack,high_severity,</group>
    <mitre>
      <id>T1204</id>
      <tactic>Execution</tactic>
      <technique>User Execution</technique>
    </mitre>
  </rule>

  <rule id="100004" level="8">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="severity">medium</field>
    <description>Sangfor NGAF: Medium severity — $(type) from $(srcip)</description>
    <group>attack,medium_severity,</group>
    <mitre>
      <id>T1078</id>
      <tactic>Defense Evasion</tactic>
      <technique>Valid Accounts</technique>
    </mitre>
  </rule>

  <rule id="100005" level="5">
    <decoded_as>sangfor-ngaf</decoded_as>
    <description>Sangfor NGAF: $(actions) — $(type) from $(srcip) to $(dstip)</description>
    <group>recon,</group>
  </rule>

  <!-- ============================================ -->
  <!-- WAF Rules                                    -->
  <!-- ============================================ -->

  <rule id="100010" level="12">
    <decoded_as>waf</decoded_as>
    <field name="rule">SQLi</field>
    <description>WAF: SQL Injection blocked from $(srcip) — $(uri)</description>
    <group>attack,sqli,</group>
    <mitre>
      <id>T1190</id>
      <tactic>Initial Access</tactic>
      <technique>Exploit Public-Facing Application</technique>
    </mitre>
  </rule>

  <rule id="100011" level="12">
    <decoded_as>waf</decoded_as>
    <field name="rule">XSS</field>
    <description>WAF: Cross-Site Scripting blocked from $(srcip) — $(uri)</description>
    <group>attack,xss,</group>
    <mitre>
      <id>T1189</id>
      <tactic>Initial Access</tactic>
      <technique>Drive-by Compromise</technique>
    </mitre>
  </rule>

  <rule id="100012" level="10">
    <decoded_as>waf</decoded_as>
    <field name="waf_status">403</field>
    <description>WAF: Request blocked (HTTP 403) from $(srcip) — rule: $(rule)</description>
    <group>attack,blocked,</group>
    <mitre>
      <id>T1562.004</id>
      <tactic>Defense Evasion</tactic>
      <technique>Impair Defenses</technique>
    </mitre>
  </rule>

  <rule id="100013" level="8">
    <decoded_as>waf</decoded_as>
    <field name="rule">LFI</field>
    <description>WAF: Local File Inclusion attempt from $(srcip) — $(uri)</description>
    <group>attack,lfi,</group>
    <mitre>
      <id>T1006</id>
      <tactic>Defense Evasion</tactic>
      <technique>Direct Volume Access</technique>
    </mitre>
  </rule>

  <rule id="100014" level="8">
    <decoded_as>waf</decoded_as>
    <field name="rule">RCE</field>
    <description>WAF: Remote Code Execution attempt from $(srcip) — $(uri)</description>
    <group>attack,rce,</group>
    <mitre>
      <id>T1203</id>
      <tactic>Execution</tactic>
      <technique>Exploitation for Client Execution</technique>
    </mitre>
  </rule>

  <rule id="100015" level="5">
    <decoded_as>waf</decoded_as>
    <description>WAF: $(rule) detected from $(srcip) — $(method) $(uri) returned $(waf_status)</description>
    <group>recon,</group>
    <mitre>
      <id>T1595</id>
      <tactic>Reconnaissance</tactic>
      <technique>Active Scanning</technique>
    </mitre>
  </rule>

  <!-- ============================================ -->
  <!-- FIM Custom Rules (Webshell & File Tamper)    -->
  <!-- ============================================ -->

  <!-- 100020: New .php file in webroot (webshell indicator) -->
  <rule id="100020" level="12">
    <if_sid>550</if_sid>
    <field name="syscheck.path" type="pattern">\.php$</field>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: Possible webshell — new .php file created: $(syscheck.path)</description>
    <group>fim,webshell,high,</group>
    <mitre>
      <id>T1505.003</id>
      <tactic>Persistence</tactic>
      <technique>Server Software Component: Web Shell</technique>
    </mitre>
  </rule>

  <rule id="100021" level="10">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">wp-config\.php$</field>
    <description>FIM: WordPress config tampered — $(syscheck.path)</description>
    <group>fim,wordpress,tamper,</group>
    <mitre>
      <id>T1565.001</id>
      <tactic>Impact</tactic>
      <technique>Data Manipulation</technique>
    </mitre>
  </rule>

  <rule id="100022" level="10">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">\.htaccess$</field>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: .htaccess file modified — $(syscheck.path)</description>
    <group>fim,htaccess,tamper,</group>
    <mitre>
      <id>T1565.001</id>
      <tactic>Impact</tactic>
      <technique>Data Manipulation</technique>
    </mitre>
  </rule>

  <rule id="100023" level="7">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">\.php$</field>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: PHP file modified — $(syscheck.path)</description>
    <group>fim,php,</group>
    <mitre>
      <id>T1505.003</id>
      <tactic>Persistence</tactic>
      <technique>Server Software Component: Web Shell</technique>
    </mitre>
  </rule>

  <rule id="100024" level="5">
    <if_sid>554</if_sid>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: File deleted from webroot — $(syscheck.path)</description>
    <group>fim,deletion,</group>
    <mitre>
      <id>T1485</id>
      <tactic>Impact</tactic>
      <technique>Data Destruction</technique>
    </mitre>
  </rule>

  <!-- 100021: wp-config.php modified -->
  <rule id="100021" level="10">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">wp-config\.php$</field>
    <description>FIM: WordPress config tampered — $(syscheck.path)</description>
    <group>fim,wordpress,tamper,</group>
  </rule>

  <!-- 100022: .htaccess modified -->
  <rule id="100022" level="10">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">\.htaccess$</field>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: .htaccess file modified — $(syscheck.path)</description>
    <group>fim,htaccess,tamper,</group>
  </rule>

  <!-- 100023: Existing .php file modified in webroot -->
  <rule id="100023" level="7">
    <if_sid>553</if_sid>
    <field name="syscheck.path" type="pattern">\.php$</field>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: PHP file modified — $(syscheck.path)</description>
    <group>fim,php,</group>
  </rule>

  <!-- 100024: File deleted from webroot -->
  <rule id="100024" level="5">
    <if_sid>554</if_sid>
    <field name="syscheck.path" type="pattern">^/home/domain</field>
    <description>FIM: File deleted from webroot — $(syscheck.path)</description>
    <group>fim,deletion,</group>
  </rule>

</group>
