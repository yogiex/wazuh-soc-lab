<group name="sangfor,ngaf,waf,firewall,seo_cloaking,">

  <!-- ============================================ -->
  <!-- Sangfor NGAF Rules                           -->
  <!-- ============================================ -->

  <rule id="100002" level="10">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="actions">blocked</field>
    <description>Sangfor NGAF: Blocked traffic from $(srcip) to $(dstip) — $(policy)</description>
    <group>attack,blocked,</group>
    <mitre>
      <id>T1562.004</id>
    </mitre>
  </rule>

  <rule id="100003" level="12">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="severity">high</field>
    <description>Sangfor NGAF: High severity alert — $(type) from $(srcip) to $(dstip)</description>
    <group>attack,high_severity,</group>
    <mitre>
      <id>T1204</id>
    </mitre>
  </rule>

  <rule id="100004" level="8">
    <decoded_as>sangfor-ngaf</decoded_as>
    <field name="severity">medium</field>
    <description>Sangfor NGAF: Medium severity — $(type) from $(srcip)</description>
    <group>attack,medium_severity,</group>
    <mitre>
      <id>T1078</id>
    </mitre>
  </rule>

  <rule id="100005" level="5">
    <decoded_as>sangfor-ngaf</decoded_as>
    <description>Sangfor NGAF: $(actions) — $(type) from $(srcip) to $(dstip)</description>
    <group>recon,</group>
  </rule>

  <!-- ============================================ -->
  <!-- WAF Rules                                    -->
  <!-- ============================================ -->

  <rule id="100010" level="12">
    <decoded_as>waf</decoded_as>
    <field name="rule">SQLi</field>
    <description>WAF: SQL Injection blocked from $(srcip) — $(uri)</description>
    <group>attack,sqli,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <rule id="100011" level="12">
    <decoded_as>waf</decoded_as>
    <field name="rule">XSS</field>
    <description>WAF: Cross-Site Scripting blocked from $(srcip) — $(uri)</description>
    <group>attack,xss,</group>
    <mitre>
      <id>T1189</id>
    </mitre>
  </rule>

  <rule id="100012" level="10">
    <decoded_as>waf</decoded_as>
    <field name="waf_status">403</field>
    <description>WAF: Request blocked (HTTP 403) from $(srcip) — rule: $(rule)</description>
    <group>attack,blocked,</group>
    <mitre>
      <id>T1562.004</id>
    </mitre>
  </rule>

  <rule id="100013" level="8">
    <decoded_as>waf</decoded_as>
    <field name="rule">LFI</field>
    <description>WAF: Local File Inclusion attempt from $(srcip) — $(uri)</description>
    <group>attack,lfi,</group>
    <mitre>
      <id>T1006</id>
    </mitre>
  </rule>

  <rule id="100014" level="8">
    <decoded_as>waf</decoded_as>
    <field name="rule">RCE</field>
    <description>WAF: Remote Code Execution attempt from $(srcip) — $(uri)</description>
    <group>attack,rce,</group>
    <mitre>
      <id>T1203</id>
    </mitre>
  </rule>

  <rule id="100015" level="5">
    <decoded_as>waf</decoded_as>
    <description>WAF: $(rule) detected from $(srcip) — $(method) $(uri) returned $(waf_status)</description>
    <group>recon,</group>
    <mitre>
      <id>T1595</id>
    </mitre>
  </rule>

  <!-- ============================================ -->
  <!-- FIM Custom Rules                             -->
  <!-- ============================================ -->
  <!--
    NOTE: Wazuh 4.14.5 limitation — <match>, <regex>, <field> do NOT work
    in child rules of syscheck events. Only <if_sid> conditions are evaluated.
    See research notes in AGENTS.md for details.
  -->

  <rule id="100020" level="7">
    <if_sid>550</if_sid>
    <description>FIM: File modified in webroot</description>
    <group>fim,syscheck,</group>
    <mitre>
      <id>T1565.001</id>
    </mitre>
  </rule>

  <rule id="100021" level="5">
    <if_sid>554</if_sid>
    <description>FIM: New file created in webroot</description>
    <group>fim,syscheck,</group>
    <mitre>
      <id>T1505.003</id>
    </mitre>
  </rule>

  <rule id="100022" level="7">
    <if_sid>553</if_sid>
    <description>FIM: File deleted from webroot</description>
    <group>fim,syscheck,</group>
    <mitre>
      <id>T1485</id>
    </mitre>
  </rule>

  <!-- ============================================ -->
  <!-- SEO Cloaking Detection Rules                 -->
  <!-- ============================================ -->
  <!-- Intermediate rule (level 0 = no alert) to aggregate FIM events for
       statistical detection. Required because if_matched_sid in Wazuh 4.14.5
       does NOT accept comma-separated rule IDs. -->
  <rule id="100025" level="0">
    <if_sid>550,554</if_sid>
    <description>SEO Cloaking FIM base event (internal)</description>
    <group>seo_cloaking,</group>
  </rule>

  <rule id="100030" level="12" frequency="4" timeframe="120">
    <if_matched_sid>100025</if_matched_sid>
    <description>SEO Cloaking: Multiple file changes in webroot — possible SEO cloaking campaign</description>
    <group>fim,seo_cloaking,critical,</group>
    <mitre>
      <id>T1565.001</id>
    </mitre>
  </rule>

  <rule id="100034" level="7">
    <if_sid>31100</if_sid>
    <field name="full_log" type="pcre2">[Gg]ooglebot|[Bb]ingbot|[Yy]andex</field>
    <field name="data.url" type="pcre2">security|cloak|data-alumni</field>
    <description>SEO Cloaking: Googlebot accessing suspicious cloaking path</description>
    <group>seo_cloaking,recon,</group>
    <mitre>
      <id>T1595</id>
    </mitre>
  </rule>

</group>
